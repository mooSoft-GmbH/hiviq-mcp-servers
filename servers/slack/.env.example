# Bot User OAuth Token — xoxb-... (required)
SLACK_BOT_TOKEN=xoxb-your-bot-token

# User OAuth Token — xoxp-... (required for search)
SLACK_USER_TOKEN=xoxp-your-user-token

# HTTP transport port (default: 3000)
MCP_PORT=3000

# Set to "http" to run as a remote MCP server, default is "stdio"
MCP_TRANSPORT=stdio
